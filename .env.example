# ===========================================
# Agentest Environment Variables
# ===========================================

# Node Environment
NODE_ENV=development

# ===========================================
# Database (PostgreSQL)
# ===========================================
DB_USER=agentest
DB_PASSWORD=agentest
DB_NAME=agentest
DB_HOST=db
DB_PORT=5432
DB_EXTERNAL_PORT=5433
DATABASE_URL=postgresql://${DB_USER}:${DB_PASSWORD}@${DB_HOST}:${DB_PORT}/${DB_NAME}

# テスト用データベース（vitest.config.tsで自動設定されるため通常は設定不要）
# テストは自動的にagentest_testデータベースに接続します
# TEST_DATABASE_URL=postgresql://${DB_USER}:${DB_PASSWORD}@${DB_HOST}:${DB_PORT}/agentest_test

# ===========================================
# Redis
# ===========================================
REDIS_PASSWORD=agentest
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_EXTERNAL_PORT=6380
REDIS_URL=redis://:${REDIS_PASSWORD}@${REDIS_HOST}:${REDIS_PORT}

# ===========================================
# MinIO (S3-compatible storage)
# ===========================================
MINIO_ROOT_USER=agentest
MINIO_ROOT_PASSWORD=agentest123
MINIO_ENDPOINT=http://minio:9000
MINIO_API_EXTERNAL_PORT=9002
MINIO_CONSOLE_EXTERNAL_PORT=9003
MINIO_BUCKET=agentest

# ===========================================
# Authentication
# ===========================================

# JWT
JWT_ACCESS_SECRET=your-access-token-secret-change-in-production
JWT_REFRESH_SECRET=your-refresh-token-secret-change-in-production

# 内部API認証（MCP↔API間通信、openssl rand -hex 32 で生成）
INTERNAL_API_SECRET=your-internal-api-secret-change-in-production

# OAuthトークン暗号化キー（openssl rand -hex 32 で生成）
TOKEN_ENCRYPTION_KEY=your-token-encryption-key-change-in-production

# TOTP秘密鍵暗号化キー（openssl rand -hex 32 で生成）
TOTP_ENCRYPTION_KEY=your-totp-encryption-key-change-in-production
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# OAuth - GitHub（未設定の場合、GitHub認証は無効になりUIからもボタンが非表示になります）
# GITHUB_CLIENT_ID=your-github-client-id
# GITHUB_CLIENT_SECRET=your-github-client-secret
# GITHUB_CALLBACK_URL=http://localhost:3001/auth/github/callback

# OAuth - Google（未設定の場合、Google認証は無効になりUIからもボタンが非表示になります）
# GOOGLE_CLIENT_ID=your-google-client-id
# GOOGLE_CLIENT_SECRET=your-google-client-secret
# GOOGLE_CALLBACK_URL=http://localhost:3001/auth/google/callback

# ===========================================
# Application URLs
# ===========================================
API_URL=http://localhost:3001
WEB_URL=http://localhost:3000
ADMIN_URL=http://localhost:3003
WS_URL=ws://localhost:3002
# OAuth 2.1 Resource Server (RFC 9728)
MCP_SERVER_URL=http://localhost:3004

# Frontend (Vite)
VITE_API_URL=http://localhost:3001
VITE_WS_URL=ws://localhost:3002

# ===========================================
# API Server
# ===========================================
API_PORT=3001
WS_PORT=3002
WEB_PORT=3000
ADMIN_PORT=3003

# ===========================================
# CORS
# ===========================================
CORS_ORIGIN=http://localhost:3000,http://localhost:3003

# ===========================================
# SMTP (Email Notifications)
# ===========================================
# 開発環境ではMailpitを使用（docker-compose.override.ymlで設定）
# Mailpit UI: http://localhost:8025
SMTP_HOST=mailpit
SMTP_PORT=1025
SMTP_USER=
SMTP_PASS=
SMTP_FROM=noreply@agentest.local
SMTP_SECURE=false

# メール認証をスキップする場合は false（SMTP設定不要になる）
REQUIRE_EMAIL_VERIFICATION=true

# ===========================================
# Logging
# ===========================================
LOG_LEVEL=debug
