{
  "name": "@agentest/mcp-server",
  "version": "0.0.1",
  "type": "module",
  "private": true,
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "pnpm build:ui && tsc",
    "build:ui": "cross-env INPUT=src/apps/test-suites-app/index.html vite build",
    "start": "node dist/index.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "oxlint src/"
  },
  "dependencies": {
    "@agentest/auth": "workspace:*",
    "@agentest/db": "workspace:*",
    "@agentest/shared": "workspace:*",
    "@modelcontextprotocol/ext-apps": "^1.0.1",
    "@modelcontextprotocol/sdk": "^1.10.0",
    "cookie-parser": "catalog:",
    "cors": "catalog:",
    "express": "catalog:",
    "helmet": "catalog:",
    "ioredis": "catalog:",
    "mime-types": "^3.0.2",
    "zod": "catalog:",
    "zod-to-json-schema": "^3.25.1"
  },
  "devDependencies": {
    "@types/cookie-parser": "catalog:",
    "@types/cors": "catalog:",
    "@types/express": "catalog:",
    "@types/mime-types": "^3.0.1",
    "@types/node": "catalog:",
    "@types/supertest": "catalog:",
    "cross-env": "^10.1.0",
    "supertest": "catalog:",
    "tsx": "^4.7.0",
    "typescript": "catalog:",
    "vite": "^6.0.0",
    "vite-plugin-singlefile": "^2.3.0",
    "vitest": "catalog:"
  }
}
